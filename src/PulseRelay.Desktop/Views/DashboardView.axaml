<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:PulseRelay.Desktop.ViewModels"
             xmlns:loc="using:PulseRelay.Desktop.Localization"
             x:Class="PulseRelay.Desktop.Views.DashboardView"
             x:DataType="vm:DashboardViewModel">

  <UserControl.Styles>
    <Style Selector="TextBlock.heart">
      <Setter Property="Foreground" Value="{StaticResource PulseAccentBrush}" />
    </Style>
    <Style Selector="TextBlock.heart.live">
      <Style.Animations>
        <Animation Duration="0:0:1.2" IterationCount="INFINITE">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="1.0" />
          </KeyFrame>
          <KeyFrame Cue="50%">
            <Setter Property="Opacity" Value="0.45" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1.0" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
    <Style Selector="Border.card">
      <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="TextBlock.muted">
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>
    <Style Selector="TextBlock.cardtitle">
      <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Ellipse.dot">
      <Setter Property="Width" Value="9" />
      <Setter Property="Height" Value="9" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="*,Auto,Auto" Margin="24">

    <!-- Hero: BPM + status -->
    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
      <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="14">
        <TextBlock Classes="heart"
                   Classes.live="{Binding IsStreaming}"
                   Text="♥" FontSize="44" VerticalAlignment="Center" />
        <TextBlock Text="{Binding BpmText}" FontSize="72" FontWeight="Light" VerticalAlignment="Center" />
        <TextBlock Text="{loc:Loc Dashboard_BpmUnit}" Classes="muted" FontSize="18"
                   VerticalAlignment="Bottom" Margin="0,0,0,14" />
      </StackPanel>
      <TextBlock HorizontalAlignment="Center" Text="{Binding StatusText}" FontSize="15" />
      <TextBlock HorizontalAlignment="Center" Classes="muted" Text="{Binding LastUpdateText}" />
    </StackPanel>

    <!-- Device / Output cards -->
    <Grid Grid.Row="1" ColumnDefinitions="*,12,*">

      <Border Grid.Column="0" Classes="card">
        <StackPanel Spacing="8">
          <TextBlock Classes="cardtitle" Text="{loc:Loc Device_CardTitle}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Classes="dot" Fill="{Binding DeviceStatusBrush}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding DeviceStateText}" />
          </StackPanel>
          <TextBlock Classes="muted" Text="{Binding DeviceLine}" TextTrimming="CharacterEllipsis" />
          <TextBlock Classes="muted" Text="{Binding ContactText}" IsVisible="{Binding HasContactInfo}" />
          <TextBlock Classes="muted" TextWrapping="Wrap"
                     Text="{loc:Loc Device_ConnectHint}" IsVisible="{Binding ShowConnectHint}" />
          <Expander IsVisible="{Binding ShowConnectHint}">
            <Expander.Header>
              <TextBlock Classes="muted" Text="{loc:Loc Guide_Share_Title}" />
            </Expander.Header>
            <StackPanel Spacing="6" Margin="0,4,0,0">
              <TextBlock Classes="muted" TextWrapping="Wrap" Text="{loc:Loc Guide_Share_Intro}" />
              <TextBlock FontWeight="SemiBold" FontSize="12" Text="{loc:Loc Guide_Share_Charge6_Title}" />
              <TextBlock Classes="muted" TextWrapping="Wrap" Text="{loc:Loc Guide_Share_Charge6_Steps}" />
              <TextBlock Classes="muted" TextWrapping="Wrap" Text="{loc:Loc Guide_Share_Charge6_Note}" />
            </StackPanel>
          </Expander>
          <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
            <Button Content="{loc:Loc Action_Reconnect}"
                    Command="{Binding ReconnectCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    IsVisible="{Binding ShowReconnect}" />
            <Button Content="{loc:Loc Action_Start}"
                    Command="{Binding StartCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    IsVisible="{Binding ShowStart}" />
            <Button Content="{loc:Loc Action_Stop}"
                    Command="{Binding StopCommand}"
                    IsEnabled="{Binding !IsBusy}"
                    IsVisible="{Binding !ShowStart}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Border Grid.Column="2" Classes="card" VerticalAlignment="Top">
        <StackPanel Spacing="8">
          <TextBlock Classes="cardtitle" Text="{loc:Loc Output_CardTitle}" />
          <StackPanel Orientation="Horizontal" Spacing="8">
            <Ellipse Classes="dot" Fill="{Binding OscStatusBrush}" VerticalAlignment="Center" />
            <TextBlock Text="{Binding OscStateText}" TextWrapping="Wrap" />
          </StackPanel>
          <TextBlock Classes="muted" Text="{Binding OscTargetText}" />
          <TextBlock Classes="muted" Text="{Binding OscAddressText}" TextTrimming="CharacterEllipsis" />
          <Button HorizontalAlignment="Right"
                  Content="{loc:Loc Output_TurnOff}"
                  Command="{Binding ToggleOscCommand}"
                  IsVisible="{Binding OscOn}" />
          <Button HorizontalAlignment="Right"
                  Content="{loc:Loc Output_TurnOn}"
                  Command="{Binding ToggleOscCommand}"
                  IsVisible="{Binding !OscOn}" />
        </StackPanel>
      </Border>

    </Grid>

    <!-- Footer: language picker -->
    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                Spacing="8" Margin="0,12,0,0">
      <TextBlock Classes="muted" VerticalAlignment="Center" Text="{loc:Loc Lang_Label}" />
      <ComboBox MinWidth="120"
                ItemsSource="{Binding LanguageOptions}"
                SelectedItem="{Binding SelectedLanguage}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:LanguageOption">
            <TextBlock Text="{Binding Label}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
    </StackPanel>

  </Grid>

</UserControl>
